# Sao chép file này thành .env rồi sửa cho khớp máy bạn:
#   cp .env.example .env   (hoc copy .env.example .env trên Windows)

# Kết nối MySQL local. Sửa user:password và tên database cho đúng.
DATABASE_URL=mysql+pymysql://root:123456@localhost:3306/mappin

# Khóa ký JWT - ĐỔI thành chuỗi ngẫu nhiên khi chạy thật.
SECRET_KEY=doi-khoa-nay-thanh-chuoi-ngau-nhien-dai-toi-thieu-32-ky-tu

# Access token ngắn hạn (phút) và refresh token dài hạn (ngày).
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30
